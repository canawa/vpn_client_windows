<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BackgroundColor">#120D0B</Color>
    <Color x:Key="SurfaceColor">#1A1614</Color>
    <Color x:Key="SurfaceContainerColor">#221B19</Color>
    <Color x:Key="SurfaceContainerHighColor">#2B2421</Color>
    <Color x:Key="SurfaceContainerHighestColor">#352D2A</Color>
    <Color x:Key="SurfaceVariantColor">#3D3230</Color>
    <Color x:Key="PrimaryColor">#E6D5C3</Color>
    <Color x:Key="PrimaryContainerColor">#413732</Color>
    <Color x:Key="OnPrimaryContainerColor">#E6D5C3</Color>
    <Color x:Key="OnSurfaceColor">#F5EDE6</Color>
    <Color x:Key="OnSurfaceVariantColor">#8E7F71</Color>
    <Color x:Key="TertiaryColor">#78DC77</Color>
    <Color x:Key="OutlineVariantColor">#4A403C</Color>
    <Color x:Key="ErrorColor">#FF8A7A</Color>
    <Color x:Key="PromoBackgroundColor">#F5F0EA</Color>
    <Color x:Key="PromoTextColor">#2C1E1B</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceContainerColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="{StaticResource SurfaceContainerHighColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush" Color="{StaticResource SurfaceContainerHighestColor}" />
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="{StaticResource OnPrimaryContainerColor}" />
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{StaticResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource OnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}" />
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="{StaticResource OutlineVariantColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="PromoBackgroundBrush" Color="{StaticResource PromoBackgroundColor}" />
    <SolidColorBrush x:Key="PromoTextBrush" Color="{StaticResource PromoTextColor}" />
    <Color x:Key="ConnectButtonFillColor">#1F1815</Color>
    <Color x:Key="ConnectButtonBorderColor">#2A211D</Color>

    <SolidColorBrush x:Key="ConnectButtonFillBrush" Color="{StaticResource ConnectButtonFillColor}" />
    <SolidColorBrush x:Key="ConnectButtonBorderBrush" Color="{StaticResource ConnectButtonBorderColor}" />
    <SolidColorBrush x:Key="MicaBorderBrush" Color="#14E6D5C3" />
    <SolidColorBrush x:Key="DividerBrush" Color="#1AE6D5C3" />
</ResourceDictionary>
