<UserControl x:Class="CoffeeManiaVPN.Controls.CountryFlag"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="56"
             Height="40">
    <Border x:Name="FlagBorder"
            CornerRadius="10"
            Background="{StaticResource SurfaceContainerHighestBrush}"
            BorderBrush="#26FFFFFF"
            BorderThickness="1"
            ClipToBounds="True" />
</UserControl>
