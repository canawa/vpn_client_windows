<UserControl x:Class="CoffeeManiaVPN.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Content="Очистить"
                Click="ClearButton_Click"
                Padding="14,8"
                HorizontalAlignment="Right"
                Margin="0,0,0,12"
                Background="{StaticResource SurfaceContainerHighBrush}"
                Foreground="{StaticResource OnSurfaceBrush}"
                BorderThickness="0"
                Cursor="Hand" />
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceContainerBrush}"
                CornerRadius="14"
                BorderBrush="{StaticResource MicaBorderBrush}"
                BorderThickness="1"
                Padding="12">
            <ScrollViewer x:Name="LogsScrollViewer"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogsTextBlock"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                           TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
