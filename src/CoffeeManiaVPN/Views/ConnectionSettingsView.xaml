<UserControl x:Class="CoffeeManiaVPN.Views.ConnectionSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CoffeeManiaVPN.Controls"
             Background="Transparent">
    <StackPanel>
        <Button Style="{StaticResource SettingsListButtonStyle}" Click="SiteSplitButton_Click">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:UiIcon Grid.Column="0"
                                   Kind="Globe"
                                   IconSize="20"
                                   IconBrush="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Раздельное туннелирование сайтов"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="4,0,16,0"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Column="2"
                           Text="›"
                           FontSize="20"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Button>
        <Border Height="1" Background="{DynamicResource DividerBrush}" />

        <Button Style="{StaticResource SettingsListButtonStyle}" Click="AppSplitButton_Click">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:UiIcon Grid.Column="0"
                                   Kind="Grid"
                                   IconSize="20"
                                   IconBrush="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Раздельное туннелирование приложений"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="4,0,16,0"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Column="2"
                           Text="›"
                           FontSize="20"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Button>
        <Border Height="1" Background="{DynamicResource DividerBrush}" />

        <Button Style="{StaticResource SettingsListButtonStyle}" Click="KillSwitchButton_Click">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:UiIcon Grid.Column="0"
                                   Kind="Shield"
                                   IconSize="20"
                                   IconBrush="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="Kill switch"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="4,0,16,0" />
                <TextBlock Grid.Column="2"
                           Text="›"
                           FontSize="20"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Button>
    </StackPanel>
</UserControl>
