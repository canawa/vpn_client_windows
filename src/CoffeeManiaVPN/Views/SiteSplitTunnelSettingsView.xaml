<UserControl x:Class="CoffeeManiaVPN.Views.SiteSplitTunnelSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <StackPanel>
        <Border Background="{StaticResource SurfaceContainerHighBrush}"
                BorderBrush="#0DE6D5C3"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Раздельное туннелирование сайтов"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceBrush}" />
                    <TextBlock Text="Управляйте, какие домены идут через VPN."
                               FontSize="12"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <CheckBox x:Name="EnabledCheckBox"
                          Grid.Column="1"
                          Margin="16,0,0,0"
                          VerticalAlignment="Center"
                          Checked="EnabledCheckBox_Changed"
                          Unchecked="EnabledCheckBox_Changed" />
            </Grid>
        </Border>

        <TextBlock Text="Режим"
                   FontSize="13"
                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10" />
        <Border Background="{StaticResource SurfaceContainerHighestBrush}"
                CornerRadius="12"
                Padding="4"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="BypassModeButton"
                        Grid.Column="0"
                        Content="Обход VPN"
                        Margin="0,0,2,0"
                        Style="{StaticResource SegmentButtonStyle}"
                        Click="ModeButton_Click"
                        Tag="bypass" />
                <Button x:Name="ProxyOnlyModeButton"
                        Grid.Column="1"
                        Content="Только через VPN"
                        Margin="2,0,0,0"
                        Style="{StaticResource SegmentButtonStyle}"
                        Click="ModeButton_Click"
                        Tag="proxyOnly" />
            </Grid>
        </Border>

        <TextBlock x:Name="ModeHintTextBlock"
                   FontSize="12"
                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <TextBlock Text="Домены"
                   FontSize="13"
                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10" />
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DomainTextBox"
                     Grid.Column="0"
                     Style="{StaticResource PrimaryTextBoxStyle}"
                     Margin="0,0,8,0" />
            <Button Grid.Column="1"
                    Content="Добавить"
                    Click="AddButton_Click"
                    Style="{StaticResource PrimaryActionButtonStyle}" />
        </Grid>

        <Border Background="{StaticResource SurfaceContainerBrush}"
                CornerRadius="14"
                BorderBrush="{StaticResource MicaBorderBrush}"
                BorderThickness="1"
                Padding="8"
                MinHeight="120">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DomainsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding}"
                                           FontSize="14"
                                           Foreground="{StaticResource OnSurfaceBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="1"
                                        Content="Удалить"
                                        Tag="{Binding}"
                                        Click="RemoveButton_Click"
                                        Style="{StaticResource GhostActionButtonStyle}"
                                        Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock x:Name="StatusTextBlock"
                   Margin="0,16,0,0"
                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                   FontSize="12"
                   TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
