<UserControl x:Class="CoffeeManiaVPN.Views.KillSwitchSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CoffeeManiaVPN.Controls"
             Background="Transparent">
    <StackPanel>
        <Border Background="{DynamicResource SurfaceContainerHighBrush}"
                BorderBrush="#0DE6D5C3"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:UiIcon Grid.Column="0"
                                 Kind="Shield"
                                 IconSize="24"
                                 IconBrush="{DynamicResource PrimaryBrush}"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Kill switch"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}" />
                    <TextBlock Text="Блокирует интернет при обрыве VPN."
                               FontSize="12"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <CheckBox x:Name="EnabledCheckBox"
                          Grid.Column="2"
                          Margin="16,0,0,0"
                          VerticalAlignment="Center"
                          Checked="EnabledCheckBox_Changed"
                          Unchecked="EnabledCheckBox_Changed" />
            </Grid>
        </Border>

        <Border Background="{DynamicResource SurfaceContainerBrush}"
                CornerRadius="14"
                BorderBrush="{DynamicResource MicaBorderBrush}"
                BorderThickness="1"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Как это работает"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}"
                           Margin="0,0,0,8" />
                <TextBlock Text="При включённом Kill Switch весь исходящий трафик блокируется, кроме VPN-приложения. Если соединение неожиданно оборвётся, доступ в интернет останется заблокированным до повторного подключения или отключения функции."
                           FontSize="13"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           TextWrapping="Wrap"
                           LineHeight="20" />
            </StackPanel>
        </Border>

        <TextBlock x:Name="StatusTextBlock"
                   Margin="0,16,0,0"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   FontSize="12"
                   TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
