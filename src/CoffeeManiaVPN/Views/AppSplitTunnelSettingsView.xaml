<UserControl x:Class="CoffeeManiaVPN.Views.AppSplitTunnelSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <StackPanel>
        <Border Background="{DynamicResource SurfaceContainerHighBrush}"
                BorderBrush="#0DE6D5C3"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Раздельное туннелирование приложений"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}" />
                    <TextBlock Text="Выберите .exe, для которых применяется отдельный маршрут."
                               FontSize="12"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <CheckBox x:Name="EnabledCheckBox"
                          Grid.Column="1"
                          Margin="16,0,0,0"
                          VerticalAlignment="Center"
                          Checked="EnabledCheckBox_Changed"
                          Unchecked="EnabledCheckBox_Changed" />
            </Grid>
        </Border>

        <TextBlock Text="Режим"
                   FontSize="13"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10" />
        <Border Background="{DynamicResource SurfaceContainerHighestBrush}"
                CornerRadius="12"
                Padding="4"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="BypassModeButton"
                        Grid.Column="0"
                        Content="Обход VPN"
                        Margin="0,0,2,0"
                        Style="{StaticResource SegmentButtonStyle}"
                        Click="ModeButton_Click"
                        Tag="bypass" />
                <Button x:Name="ProxyOnlyModeButton"
                        Grid.Column="1"
                        Content="Только через VPN"
                        Margin="2,0,0,0"
                        Style="{StaticResource SegmentButtonStyle}"
                        Click="ModeButton_Click"
                        Tag="proxyOnly" />
            </Grid>
        </Border>

        <TextBlock x:Name="ModeHintTextBlock"
                   FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <Button Content="Добавить приложение"
                Click="AddButton_Click"
                Style="{StaticResource PrimaryActionButtonStyle}"
                HorizontalAlignment="Left"
                Margin="0,0,0,12" />

        <Border Background="{DynamicResource SurfaceContainerBrush}"
                CornerRadius="14"
                BorderBrush="{DynamicResource MicaBorderBrush}"
                BorderThickness="1"
                Padding="8"
                MinHeight="120">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AppsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding}"
                                           FontSize="13"
                                           Foreground="{DynamicResource OnSurfaceBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="Удалить"
                                        Tag="{Binding}"
                                        Click="RemoveButton_Click"
                                        Style="{StaticResource GhostActionButtonStyle}"
                                        Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock x:Name="StatusTextBlock"
                   Margin="0,16,0,0"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   FontSize="12"
                   TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
