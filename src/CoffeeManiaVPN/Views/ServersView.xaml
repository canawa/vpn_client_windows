<UserControl x:Class="CoffeeManiaVPN.Views.ServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CoffeeManiaVPN.Models"
             xmlns:controls="clr-namespace:CoffeeManiaVPN.Controls"
             Background="Transparent"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <DataTemplate x:Key="ServerCardTemplate" DataType="{x:Type local:ServerListItem}">
            <Border x:Name="CardBorder"
                    Padding="16"
                    CornerRadius="16"
                    Background="{StaticResource SurfaceContainerHighBrush}"
                    BorderThickness="1.5"
                    BorderBrush="Transparent"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <controls:CountryFlag Grid.Row="0"
                                          Grid.RowSpan="2"
                                          CountryCode="{Binding CountryCode}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,14,0" />
                    <controls:EmojiTextBlock Grid.Column="1"
                                             Grid.Row="0"
                                             SourceText="{Binding Name}"
                                             FontWeight="SemiBold"
                                             FontSize="15"
                                             TextBrush="{StaticResource OnSurfaceBrush}"
                                             VerticalAlignment="Center" />
                    <Grid Grid.Column="2"
                          Grid.Row="0"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="12,0,0,0"
                          MinWidth="52">
                        <TextBlock x:Name="PingResultText"
                                   Text="{Binding PingText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <ScaleTransform x:Name="PingResultScale" ScaleX="1" ScaleY="1" />
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TertiaryBrush}" />
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPinging}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PingMs}" Value="{x:Null}">
                                            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PingMs}" Value="-1">
                                            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel x:Name="PingLoadingPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <Ellipse x:Name="PingDot1"
                                     Width="5"
                                     Height="5"
                                     Margin="2,0"
                                     Opacity="0.3"
                                     Fill="{StaticResource TertiaryBrush}" />
                            <Ellipse x:Name="PingDot2"
                                     Width="5"
                                     Height="5"
                                     Margin="2,0"
                                     Opacity="0.3"
                                     Fill="{StaticResource TertiaryBrush}" />
                            <Ellipse x:Name="PingDot3"
                                     Width="5"
                                     Height="5"
                                     Margin="2,0"
                                     Opacity="0.3"
                                     Fill="{StaticResource TertiaryBrush}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <Border Style="{StaticResource ProtocolBadgeStyle}" Margin="0,0,8,0">
                            <TextBlock Text="{Binding ProtocolBadge}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}" />
                        </Border>
                        <TextBlock Text="{Binding ProtocolHint}"
                                   FontSize="12"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                             Value="True">
                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                             Value="True">
                    <Setter TargetName="CardBorder" Property="Background" Value="#352D2A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPinging}" Value="True">
                    <Setter TargetName="PingLoadingPanel" Property="Visibility" Value="Visible" />
                    <Setter TargetName="PingResultText" Property="Visibility" Value="Collapsed" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="PingDotsStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="PingDot1"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.25"
                                                 To="1"
                                                 Duration="0:0:0.35"
                                                 AutoReverse="True" />
                                <DoubleAnimation Storyboard.TargetName="PingDot2"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.25"
                                                 To="1"
                                                 Duration="0:0:0.35"
                                                 AutoReverse="True"
                                                 BeginTime="0:0:0.12" />
                                <DoubleAnimation Storyboard.TargetName="PingDot3"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.25"
                                                 To="1"
                                                 Duration="0:0:0.35"
                                                 AutoReverse="True"
                                                 BeginTime="0:0:0.24" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="PingDotsStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPinging}" Value="False">
                    <Setter TargetName="PingLoadingPanel" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="PingResultText" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPinging}" Value="False" />
                        <Condition Binding="{Binding HasPingResult}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="PingResultScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 From="0.85"
                                                 To="1"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="PingResultScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 From="0.85"
                                                 To="1"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                </MultiDataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource MicaCardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="КОФЕМАНИЯ ВПН"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurfaceBrush}" />
                        <TextBlock x:Name="SubscriptionLabelTextBlock"
                                   Text="Бессрочная подписка"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   FontSize="13"
                                   Margin="0,4,0,0" />
                        <TextBlock x:Name="HeaderStatusTextBlock"
                                   Text=""
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="RefreshButton"
                                Style="{StaticResource IconButtonStyle}"
                                Click="RefreshButton_Click"
                                ToolTip="Обновить подписку">
                            <TextBlock Text="↻" FontSize="18" />
                        </Button>
                        <Button x:Name="PingButton"
                                Style="{StaticResource IconButtonStyle}"
                                Click="PingButton_Click"
                                ToolTip="Пропинговать серверы">
                            <TextBlock Text="⏱" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <TextBlock x:Name="ServerCountTextBlock"
                               Text="0"
                               FontWeight="Bold"
                               FontSize="15"
                               Foreground="{StaticResource OnSurfaceBrush}" />
                    <TextBlock Text=" Серверов"
                               FontSize="15"
                               Foreground="{StaticResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid Margin="0,16,0,0"
                      x:Name="UsageBarGrid"
                      SizeChanged="UsageBarGrid_SizeChanged">
                    <Border Height="6"
                            CornerRadius="3"
                            Background="{StaticResource SurfaceContainerHighestBrush}" />
                    <Border x:Name="UsageProgressBar"
                            Height="6"
                            CornerRadius="3"
                            Background="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Left"
                            Width="0" />
                    <Ellipse Width="10" Height="10"
                             Fill="{StaticResource OnSurfaceBrush}"
                             HorizontalAlignment="Left"
                             Margin="0,0,0,0"
                             x:Name="UsageProgressDot"
                             VerticalAlignment="Center" />
                </Grid>
                <TextBlock x:Name="UsageTextBlock"
                           Text="— / —"
                           FontSize="12"
                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Right"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <ListBox x:Name="ServersListBox"
                 Grid.Row="1"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemTemplate="{StaticResource ServerCardTemplate}"
                 SelectionChanged="ServersListBox_SelectionChanged"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.CanContentScroll="False">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <controls:RoundedImage Grid.Row="2"
                               Margin="0,16,0,0"
                               Style="{StaticResource ImageBannerStyle}"
                               CornerRadius="24"
                               MouseLeftButtonUp="TelegramBanner_Click">
            <controls:RoundedImage.Source>
                <BitmapImage UriSource="pack://siteoforigin:,,,/Assets/tg_banner.png" />
            </controls:RoundedImage.Source>
        </controls:RoundedImage>
    </Grid>
</UserControl>
