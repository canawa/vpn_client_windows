<UserControl x:Class="CoffeeManiaVPN.Views.SubscriptionSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <StackPanel>
        <TextBlock Text="Ссылка подписки"
                   FontSize="13"
                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10" />
        <TextBox x:Name="SubscriptionUrlTextBox"
                 Style="{StaticResource PrimaryTextBoxStyle}"
                 Margin="0,0,0,16" />
        <Button Content="Обновить подписку"
                Click="RefreshButton_Click"
                Padding="18,12"
                Background="{StaticResource PrimaryContainerBrush}"
                Foreground="{StaticResource OnPrimaryContainerBrush}"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Left"
                FontWeight="SemiBold" />
        <TextBlock x:Name="StatusTextBlock"
                   Margin="0,16,0,0"
                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                   FontSize="12"
                   TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
