<UserControl x:Class="CoffeeManiaVPN.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CoffeeManiaVPN.Controls"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                  HorizontalScrollBarVisibility="Disabled">
    <StackPanel>
        <Button Style="{StaticResource SettingsListButtonStyle}" Click="ServersButton_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:EmojiIcon Emoji="🌐" IconSize="18" Width="28" />
                <TextBlock Grid.Column="1" Text="Серверы" FontSize="16" />
                <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="{StaticResource OnSurfaceVariantBrush}" />
            </Grid>
        </Button>
        <Border Height="1" Background="{StaticResource DividerBrush}" />

        <Button Style="{StaticResource SettingsListButtonStyle}" Click="ConnectionButton_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:EmojiIcon Emoji="📡" IconSize="18" Width="28" />
                <TextBlock Grid.Column="1" Text="Соединение" FontSize="16" />
                <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="{StaticResource OnSurfaceVariantBrush}" />
            </Grid>
        </Button>
        <Border Height="1" Background="{StaticResource DividerBrush}" />

        <Button Style="{StaticResource SettingsListButtonStyle}" Click="SubscriptionButton_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:EmojiIcon Emoji="🔗" IconSize="18" Width="28" />
                <TextBlock Grid.Column="1" Text="Подписка" FontSize="16" />
                <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="{StaticResource OnSurfaceVariantBrush}" />
            </Grid>
        </Button>
        <Border Height="1" Background="{StaticResource DividerBrush}" />

        <Button Style="{StaticResource SettingsListButtonStyle}" IsEnabled="False" Opacity="0.55">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:EmojiIcon Emoji="🎨" IconSize="18" Width="28" />
                <TextBlock Grid.Column="1" Text="Тема" FontSize="16" />
                <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="{StaticResource OnSurfaceVariantBrush}" />
            </Grid>
        </Button>
        <Border Height="1" Background="{StaticResource DividerBrush}" />

        <Button Style="{StaticResource SettingsListButtonStyle}" Click="LogsButton_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:EmojiIcon Emoji="🐞" IconSize="18" Width="28" />
                <TextBlock Grid.Column="1" Text="Логи" FontSize="16" />
                <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="{StaticResource OnSurfaceVariantBrush}" />
            </Grid>
        </Button>
        <Border Height="1" Background="{StaticResource DividerBrush}" />

        <Button Style="{StaticResource SettingsListButtonStyle}" Click="AboutButton_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="ℹ" FontSize="18" Width="28" />
                <TextBlock Grid.Column="1" Text="О КОФЕМАНИЯ ВПН" FontSize="16" />
                <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="{StaticResource OnSurfaceVariantBrush}" />
            </Grid>
        </Button>
        <Border Height="1" Background="{StaticResource DividerBrush}" />

        <Button Style="{StaticResource SettingsListButtonStyle}" Click="CloseAppButton_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="✕" FontSize="18" Width="28" Foreground="{StaticResource ErrorBrush}" />
                <TextBlock Grid.Column="1"
                           Text="Закрыть приложение"
                           FontSize="16"
                           Foreground="{StaticResource ErrorBrush}" />
            </Grid>
        </Button>

        <TextBlock x:Name="StatusTextBlock"
                   Margin="4,20,0,0"
                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                   FontSize="12"
                   TextWrapping="Wrap" />
    </StackPanel>
    </ScrollViewer>
</UserControl>
