<UserControl x:Class="CoffeeManiaVPN.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CoffeeManiaVPN.Controls"
             Background="Transparent">
    <Grid>
        <StackPanel VerticalAlignment="Center">
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
            <TextBlock Text="СТАТУС"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="{StaticResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusTextBlock"
                       Text="Отключено"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="{StaticResource OnSurfaceBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0" />
        </StackPanel>

        <Grid HorizontalAlignment="Center"
              Margin="0,0,0,24">
            <Button x:Name="ConnectButton"
                    Width="200"
                    Height="200"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="ConnectButton_Click"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="200"
                              Height="200"
                              RenderTransformOrigin="0.5,0.5">
                            <Ellipse x:Name="OuterRing"
                                     Width="200"
                                     Height="200"
                                     Fill="{StaticResource ConnectButtonFillBrush}"
                                     Stroke="{StaticResource ConnectButtonBorderBrush}"
                                     StrokeThickness="1.5" />
                            <controls:LogoMark x:Name="ConnectLogo"
                                               Width="92"
                                               Height="92"
                                               IconBrush="{StaticResource OnSurfaceBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterRing" Property="Stroke" Value="#3A302C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Grid x:Name="TrafficStatsPanel"
              Margin="0,0,0,28"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <TextBlock Text="↑"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{StaticResource TertiaryBrush}"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="UploadSpeedTextBlock"
                           Text="0 KB/s"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{StaticResource OnSurfaceBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="28,0">
                <TextBlock Text="◷"
                           FontSize="14"
                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="ConnectionTimerTextBlock"
                           Text="00:00"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{StaticResource OnSurfaceBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="↓"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{StaticResource TertiaryBrush}"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="DownloadSpeedTextBlock"
                           Text="0 KB/s"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{StaticResource OnSurfaceBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Border Style="{StaticResource GlassCardStyle}"
                Padding="18"
                Margin="0,0,0,16"
                Cursor="Hand"
                MouseLeftButtonUp="ServerCard_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:CountryFlag x:Name="ServerFlag"
                                      Margin="0,0,14,0" />
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="ТЕКУЩИЙ СЕРВЕР"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource OnSurfaceVariantBrush}" />
                    <controls:EmojiTextBlock x:Name="CurrentServerTextBlock"
                                             SourceText="Не выбран"
                                             FontSize="17"
                                             FontWeight="SemiBold"
                                             TextBrush="{StaticResource OnSurfaceBrush}"
                                             Margin="0,4,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="›"
                           FontSize="22"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <controls:RoundedImage Style="{StaticResource ImageBannerStyle}"
                               CornerRadius="24"
                               HorizontalAlignment="Center"
                               MouseLeftButtonUp="PromoBanner_Click">
            <controls:RoundedImage.Source>
                <BitmapImage UriSource="pack://siteoforigin:,,,/Assets/site.jpg" />
            </controls:RoundedImage.Source>
        </controls:RoundedImage>
        </StackPanel>
    </Grid>
</UserControl>
