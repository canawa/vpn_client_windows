<UserControl x:Class="CoffeeManiaVPN.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CoffeeManiaVPN.Controls"
             Background="Transparent">
    <StackPanel HorizontalAlignment="Center" Margin="0,24,0,0">
        <Border Width="88" Height="88"
                CornerRadius="22"
                Background="{StaticResource SurfaceContainerHighBrush}"
                HorizontalAlignment="Center"
                Margin="0,0,0,20">
            <controls:LogoMark Width="48" Height="48"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
        </Border>
        <TextBlock Text="КОФЕМАНИЯ ВПН"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{StaticResource OnSurfaceBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="v1.0.0"
                   FontSize="14"
                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0" />
    </StackPanel>
</UserControl>
