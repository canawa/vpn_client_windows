<Window x:Class="CoffeeManiaVPN.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CoffeeManiaVPN.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Кофемания ВПН"
        Height="820"
        Width="960"
        MinHeight="440"
        MinWidth="460"
        SizeChanged="Window_SizeChanged"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        FontFamily="{StaticResource FontBody}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="56"
                             CornerRadius="14"
                             GlassFrameThickness="0"
                             ResizeBorderThickness="6"
                             UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Border x:Name="RootBorder"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource MicaBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            ClipToBounds="True"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="268" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Боковая навигация -->
        <Border x:Name="SidebarHost"
                Grid.Column="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,1,0"
                ClipToBounds="True">
            <Viewbox x:Name="SidebarViewbox"
                     Stretch="Uniform"
                     StretchDirection="DownOnly"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Left">
            <StackPanel x:Name="SidebarPanel" Width="228" Margin="20,28,20,24">
                <StackPanel x:Name="BrandPanel"
                            Orientation="Horizontal"
                            Margin="0,0,0,24"
                            VerticalAlignment="Center">
                    <Border Width="40"
                            Height="40"
                            CornerRadius="9"
                            Background="{DynamicResource BrandLogoBackgroundBrush}"
                            SnapsToDevicePixels="True">
                        <controls:LogoMark Width="36"
                                           Height="36"
                                           IconBrush="{DynamicResource BrandLogoIconBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="BrandTextBlock"
                               Text="COFFEEMANIA"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrandTextBrush}"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button x:Name="NavHomeButton"
                        Style="{StaticResource NavPillActiveButtonStyle}"
                        Click="NavHomeButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <controls:LogoMark x:Name="NavHomeIcon"
                                           Width="22"
                                           Height="22"
                                           IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           Margin="0,0,14,0"
                                           VerticalAlignment="Center" />
                        <TextBlock x:Name="NavHomeLabel"
                                   Text="Главная"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="NavServersButton"
                        Style="{StaticResource NavPillButtonStyle}"
                        Click="NavServersButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <controls:UiIcon x:Name="NavServersIcon"
                                         Kind="Globe"
                                         IconSize="22"
                                         IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                         Margin="0,0,14,0"
                                         VerticalAlignment="Center" />
                        <TextBlock x:Name="NavServersLabel"
                                   Text="Серверы"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="NavSettingsButton"
                        Style="{StaticResource NavPillButtonStyle}"
                        Click="NavSettingsButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <controls:UiIcon x:Name="NavSettingsIcon"
                                         Kind="Settings"
                                         IconSize="22"
                                         IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                         Margin="0,0,14,0"
                                         VerticalAlignment="Center" />
                        <TextBlock x:Name="NavSettingsLabel"
                                   Text="Настройки"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
            </Viewbox>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0,12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BackButton"
                                Style="{StaticResource IconButtonStyle}"
                                Width="36" Height="36"
                                Visibility="Collapsed"
                                Click="BackButton_Click"
                                Margin="0,0,4,0">
                            <TextBlock Text="←" FontSize="18" />
                        </Button>
                        <TextBlock x:Name="PageTitleTextBlock"
                                   Text="Главная"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButtonStyle}" Click="MinimizeButton_Click">
                            <TextBlock Text="—" />
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Click="MaximizeButton_Click">
                            <TextBlock Text="▢" FontSize="12" />
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Click="CloseButton_Click">
                            <TextBlock Text="✕" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{DynamicResource BackgroundBrush}"
                    ClipToBounds="True">
                <Grid x:Name="ContentHostGrid" Margin="24,20,24,32">
                    <ContentControl x:Name="PageHost"
                                    MaxWidth="560"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Border>
</Window>
