<Window x:Class="CoffeeManiaVPN.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CoffeeManiaVPN.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Кофемания ВПН"
        Height="820"
        Width="960"
        MinHeight="700"
        MinWidth="820"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="56"
                             CornerRadius="0"
                             GlassFrameThickness="0"
                             ResizeBorderThickness="6"
                             UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Border Background="{StaticResource SurfaceBrush}"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True"
            Margin="-1">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Боковая навигация -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="16,24,16,24">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="40"
                            Height="40"
                            CornerRadius="12"
                            Background="{StaticResource SurfaceContainerHighBrush}"
                            Margin="0,0,12,0">
                        <controls:LogoMark Width="22"
                                           Height="22"
                                           IconBrush="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="КОФЕМАНИЯ"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OnSurfaceBrush}" />
                        <TextBlock Text="ВПН"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="NavHomeButton"
                        Style="{StaticResource NavPillActiveButtonStyle}"
                        Click="NavHomeButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <controls:LogoMark Width="18"
                                           Height="18"
                                           IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center" />
                        <TextBlock Text="Главная"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="NavServersButton"
                        Style="{StaticResource NavPillButtonStyle}"
                        Click="NavServersButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <controls:EmojiIcon Emoji="🌐"
                                            IconSize="18"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center" />
                        <TextBlock Text="Серверы"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="NavSettingsButton"
                        Style="{StaticResource NavPillButtonStyle}"
                        Click="NavSettingsButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <controls:EmojiIcon Emoji="⚙"
                                            IconSize="18"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center" />
                        <TextBlock Text="Настройки"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0,12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BackButton"
                                Style="{StaticResource IconButtonStyle}"
                                Width="36" Height="36"
                                Visibility="Collapsed"
                                Click="BackButton_Click"
                                Margin="0,0,4,0">
                            <TextBlock Text="←" FontSize="18" />
                        </Button>
                        <TextBlock x:Name="PageTitleTextBlock"
                                   Text="Главная"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurfaceBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource IconButtonStyle}"
                                Click="SettingsButton_Click"
                                ToolTip="Настройки"
                                Margin="0,0,8,0">
                            <controls:EmojiIcon Emoji="⚙" IconSize="16" />
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Click="MinimizeButton_Click">
                            <TextBlock Text="—" />
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Click="MaximizeButton_Click">
                            <TextBlock Text="▢" FontSize="12" />
                        </Button>
                        <Button Style="{StaticResource IconButtonStyle}" Click="CloseButton_Click">
                            <TextBlock Text="✕" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource BackgroundBrush}">
                <Grid Margin="24,20,24,32">
                    <ContentControl x:Name="PageHost"
                                    MaxWidth="560"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Border>
</Window>
